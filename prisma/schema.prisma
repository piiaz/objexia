// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User Account (Updated for Auth & Collaboration)
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String?   // Optional because Google users won't have a password
  firstName String
  lastName  String?
  jobTitle  String?
  avatarUrl String?
  age       String?
  gender    String?
  theme     String?   @default("light") // <--- NEW: Theme Preference
  
  // --- AUTH FIELDS ---
  provider   String?   @default("email") // 'email' or 'google'
  isVerified Boolean   @default(false)
  otp        String?   // 6-digit code
  otpExpiry  DateTime? // Expiry time
  
  createdAt DateTime  @default(now())
  
  roadmaps       Roadmap[]
  sharedRoadmaps RoadmapAccess[] // <--- ADDED: Reverse relation for collaboration
}

// 2. The Roadmap Container
model Roadmap {
  id          String   @id @default(uuid())
  order       Int      @default(0)
  title       String
  description String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  lastEdited  DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lanes       Lane[]
  items       Item[]
  milestones  Milestone[]
  
  startDate    String?  
  endDate      String?
  timeView     String   @default("Month") // "Quarter" | "Month" | "Week"
  showWeekends Boolean  @default(false)
  
  collaborators RoadmapAccess[] // <--- ADDED: Links to the access table

  @@unique([userId, title])
}

// 3. Tracks/Lanes
model Lane {
  id        String   @id @default(uuid())
  title     String
  color     String
  type      String   // 'lane' or 'milestone'
  order     Int      @default(0) 
  
  roadmapId String
  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

// 4. Objectives/Items
model Item {
  id          String   @id @default(uuid())
  title       String
  startDate   String
  endDate     String
  progress    Int      @default(0)
  description String?
  trackIndex  Int      @default(0)
  
  groupId     String   // Links to a Lane ID
  
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

// 5. Milestones
model Milestone {
  id          String   @id @default(uuid())
  title       String
  date        String
  icon        String
  color       String
  trackIndex  Int      @default(0)
  
  groupId     String
  
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

// --- NEW COLLABORATION MODELS ---

// Add this new Enum for Roles
enum Role {
  OWNER
  EDITOR
  VIEWER
}

// Add this new Model to link Users and Roadmaps
model RoadmapAccess {
  id        String   @id @default(uuid())
  roadmapId String
  userId    String
  role      Role     @default(VIEWER)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roadmap   Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user can only have one specific role per roadmap
  @@unique([roadmapId, userId]) 
}



model PendingUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  firstName String
  lastName  String?
  jobTitle  String?  
  age       String?  
  otp       String   
  expiresAt DateTime 
  createdAt DateTime @default(now())
}